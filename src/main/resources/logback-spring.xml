<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="UNKNOWN_SERVICE"/>

    <property name="LOG_PATH" value="/app/logs"/>
    <property name="APP_NAME" value="order-payment-service"/>
    <property name="VERSION" value="${spring.profiles.active:-unknown}"/>

    <appender name="ROLLING_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}.log</file>
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp/>
                <logLevel/>
                <threadName/>
                <loggerName/>
                <pattern>
                    <pattern>
                        {"message":"%msg"}
                    </pattern>
                </pattern>
                <mdc/>
                <stackTrace/>
            </providers>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
    </appender>

    <appender name="WEBHOOK" class="shop.wannab.order_payment_service.advice.alert.WebhookAppender">
        <webhookUrl>https://nhnacademy.dooray.com/services/3204376758577275363/4094430404194879315/qtRDdsQ5TWuqQrXgavQE5g</webhookUrl>
        <minLevel>ERROR</minLevel>
    </appender>

    <logger name="shop.wannab.order_payment_service" level="DEBUG">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <springProfile name="v1,v2">
        <root level="DEBUG">
            <appender-ref ref="ROLLING_FILE"/>
            <appender-ref ref="WEBHOOK"/>
        </root>
    </springProfile>

    <springProfile name="!v1">
        <springProfile name="!v2">
            <root level="INFO">
                <appender-ref ref="CONSOLE"/>
            </root>
        </springProfile>
    </springProfile>
</configuration>